# Supabase — get from: Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — get from: Project Settings → API → service_role
# KEEP SECRET — bypasses RLS, only used in Node scripts, never in the browser
SUPABASE_SERVICE_KEY=your-service-role-key-here

# CricketData.org — get from: https://cricketdata.org/ (free: 100 calls/day)
VITE_CRICAPI_KEY=your-cricapi-key-here
# Script alias (Node scripts can't read VITE_* vars)
CRICAPI_KEY=your-cricapi-key-here
